#!/bin/bash
# List ZFS clones grouped by parent (origin),
# and display the associated GNS3 project name if a .gns3 file exists
# in the parent or clone mount directory.

set -e

tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT

# Collect all parent/clone pairs
zfs list -H -o name,origin | while IFS="$(printf '\t')" read -r dataset origin; do
    [ "$origin" = "-" ] && continue
    parent="${origin%%@*}"
    snap="${origin#*@}"
    printf '%s\t%s\t%s\n' "$parent" "$dataset" "$snap"
done > "$tmpfile"

if [ ! -s "$tmpfile" ]; then
    echo "No ZFS clones found."
    exit 0
fi

# Return the GNS3 project name (without suffix) found in the mountpoint
# of the given dataset, or nothing.
get_project_name() {
    _mp=$(zfs get -H -o value mountpoint "$1" 2>/dev/null)
    [ -z "$_mp" ] || [ "$_mp" = "none" ] || [ "$_mp" = "legacy" ] && return
    [ -d "$_mp" ] || return
    _gns3=$(find "$_mp" -maxdepth 1 -name '*.gns3' -print -quit 2>/dev/null)
    [ -n "$_gns3" ] && basename "$_gns3" .gns3
}

# Extract the list of unique parents (in order of first appearance)
parents=$(awk -F'\t' '!seen[$1]++ { print $1 }' "$tmpfile")

for parent in $parents; do
    # Get the snapshot name from the first clone entry for this parent
    snap=$(awk -F'\t' -v p="$parent" '$1 == p { print $3; exit }' "$tmpfile")
    project=$(get_project_name "$parent")
    if [ -n "$project" ]; then
        printf "Parent: %s@%s  (project: %s)\n" "$parent" "$snap" "$project"
    else
        printf "Parent: %s@%s\n" "$parent" "$snap"
    fi

    awk -F'\t' -v p="$parent" '$1 == p { print $2 }' "$tmpfile" | while read -r clone; do
        clone_project=$(get_project_name "$clone")
        if [ -n "$clone_project" ]; then
            printf "  Clone: %s  (project: %s)\n" "$clone" "$clone_project"
        else
            printf "  Clone: %s\n" "$clone"
        fi
    done

    echo ""
done

